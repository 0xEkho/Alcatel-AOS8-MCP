# Copy this file to .env and fill in the values
# cp .env.example .env
# WARNING: Never commit .env to version control — it contains sensitive credentials

# ---------------------------------------------------------------------------
# MCP Server
# ---------------------------------------------------------------------------

# Display name shown in MCP clients (e.g. Claude Desktop, MCP Inspector)
MCP_SERVER_NAME=alcatel-aos8-mcp

# Server version (must match the version in pyproject.toml)
MCP_SERVER_VERSION=1.1.0

# MCP transport: "streamable-http" (recommended) or "sse"
MCP_TRANSPORT=streamable-http

# Server listen address (0.0.0.0 = all interfaces)
MCP_HOST=0.0.0.0

# MCP server listen port
MCP_PORT=8080

# ---------------------------------------------------------------------------
# MCP Security
# ---------------------------------------------------------------------------

# API key required in the Authorization: Bearer <MCP_API_KEY> header
# Leave empty to disable authentication (not recommended in production)
MCP_API_KEY=

# Comma-separated list of allowed IP ranges (CIDR notation)
# Example: 127.0.0.1/32 for localhost only, 10.0.0.0/8 for entire private network
MCP_ALLOWED_IPS=127.0.0.1/32,10.0.0.0/8,192.168.0.0/16

# ---------------------------------------------------------------------------
# SSH Global Credentials (used for all switches)
# ---------------------------------------------------------------------------

# Default SSH username used to connect to AOS8 OmniSwitches
AOS_GLOBAL_USERNAME=admin

# Default SSH password — DO NOT commit this value
AOS_GLOBAL_PASSWORD=switch

# ---------------------------------------------------------------------------
# SSH Zone Fallback Credentials (fallback by /16 subnet: 10.X.0.0/16)
# X = second octet of target IP
# If set, these credentials override AOS_GLOBAL for the matching /16 subnet
# ---------------------------------------------------------------------------

# Zone 1 : 10.1.0.0/16
AOS_ZONE1_USERNAME=
AOS_ZONE1_PASSWORD=

# Zone 2 : 10.2.0.0/16
AOS_ZONE2_USERNAME=
AOS_ZONE2_PASSWORD=

# Add as many zones as needed following the pattern:
# AOS_ZONE{X}_USERNAME / AOS_ZONE{X}_PASSWORD  (X = second octet of the target network)

# ---------------------------------------------------------------------------
# SSH Settings
# ---------------------------------------------------------------------------

# Strict SSH host key checking (true = secure, false = ignore unknown hosts)
# In production, set to true and populate SSH_KNOWN_HOSTS_FILE
SSH_STRICT_HOST_KEY=false

# Path to the SSH known_hosts file (used when SSH_STRICT_HOST_KEY=true)
# This file is excluded from git (see .gitignore)
SSH_KNOWN_HOSTS_FILE=./known_hosts

# SSH connection timeout in seconds
SSH_CONNECT_TIMEOUT=10

# SSH command execution timeout in seconds
SSH_COMMAND_TIMEOUT=30

# ---------------------------------------------------------------------------
# Teams Approval Workflow (PoE Reboot)
# ---------------------------------------------------------------------------

# Teams Incoming Webhook URL for posting approval cards
# Get from Teams > Channel > Connectors > Incoming Webhook
# Format : https://xxxxx.webhook.office.com/webhookb2/...
TEAMS_WEBHOOK_URL=
# Shared secret token for validating webhook callback authenticity
# Generate a strong random value (e.g. openssl rand -hex 32)
# This token is validated in the query string of incoming webhook requests
WEBHOOK_SECRET=

# Public URL of the MCP server, reachable from clients (LAN or internet)
# Used to build the callback URLs embedded in Teams approval cards
# Format: http(s)://<ip-or-hostname>:<port>  (no trailing slash)
# Example: http://192.168.1.10:8080
MCP_PUBLIC_URL=

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------

# Log verbosity level — accepted values: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO
